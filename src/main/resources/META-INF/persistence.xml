<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="cotisationsPU" transaction-type="RESOURCE_LOCAL">

        <!-- PROVIDER HIBERNATE - obligatoire sur Tomcat -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>sn.ucad.cotisations.model.Membre</class>
        <class>sn.ucad.cotisations.model.Cotisation</class>
        <class>sn.ucad.cotisations.model.Amende</class>
        <class>sn.ucad.cotisations.model.Connexion</class>
        <class>sn.ucad.cotisations.model.Parametre</class>

        <properties>
            <!-- Connexion MySQL -->
            <property name="jakarta.persistence.jdbc.driver"
                      value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url"
value="jdbc:mysql://mysql.cotisations.svc.cluster.local:3306/gestion_cotisations?useSSL=false&amp;allowPublicKeyRetrieval=true&amp;serverTimezone=UTC"/>
            <property name="jakarta.persistence.jdbc.user"     value="DB_USER_PLACEHOLDER"/>
            <property name="jakarta.persistence.jdbc.password" value="DB_PASSWORD_PLACEHOLDER"/>

            <!-- Hibernate -->
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.MySQLDialect"/>
            <!-- "update" : crée/complète les tables manquantes (ex: connexion) sans rien supprimer -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql"     value="true"/>
            <property name="hibernate.format_sql"   value="true"/>
        </properties>

    </persistence-unit>

</persistence>